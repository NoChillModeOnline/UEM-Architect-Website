{{!< default}}

{{#post}}

<article class="post-full {{post_class}} {{#unless feature_image}}post-full--no-feature-image{{/unless}}" data-post-id="{{id}}">

  <!-- ── Post Header ── -->
  <header class="post-full-header">
    <div class="container container--narrow">

      {{#primary_tag}}
      <a href="{{url}}" class="post-full-tag">{{name}}</a>
      {{/primary_tag}}

      <h1 class="post-full-title">{{title}}</h1>

      {{#if custom_excerpt}}
      <p class="post-full-excerpt">{{custom_excerpt}}</p>
      {{/if}}

      <div class="post-full-meta">
        <div class="post-full-author">
          {{#foreach authors}}
            {{#if profile_image}}
              <a href="{{url}}" aria-label="{{name}}">
                <img class="post-full-author__avatar"
                  src="{{img_url profile_image size="xs"}}"
                  alt="{{name}}" loading="lazy" />
              </a>
            {{else}}
              <a href="{{url}}" class="post-full-author__initials" aria-label="{{name}}">
                {{name.[0]}}
              </a>
            {{/if}}
          {{/foreach}}
          <div class="post-full-author__info">
            <span class="post-full-author__name">
              {{#foreach authors}}
                <a href="{{url}}">{{name}}</a>{{#unless @last}}, {{/unless}}
              {{/foreach}}
            </span>
            <div class="post-full-author__details">
              <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
              <span aria-hidden="true">·</span>
              <span>{{reading_time}}</span>
            </div>
          </div>
        </div>

        <div class="post-full-share">
          <button class="share-btn" id="share-btn" type="button" aria-label="Share this article">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            Share
          </button>
        </div>
      </div>

    </div>
  </header>

  <!-- ── Feature Image ── -->
  {{#if feature_image}}
  <figure class="post-full-image">
    <img
      src="{{img_url feature_image size="xl"}}"
      srcset="{{img_url feature_image size="s"}} 300w,
              {{img_url feature_image size="m"}} 600w,
              {{img_url feature_image size="l"}} 1000w,
              {{img_url feature_image size="xl"}} 2000w"
      sizes="(max-width: 1400px) 100vw, 1400px"
      alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
      loading="eager"
    />
    {{#if feature_image_caption}}
    <figcaption>{{feature_image_caption}}</figcaption>
    {{/if}}
  </figure>
  {{/if}}

  <!-- ── Post Content ── -->
  <div class="post-full-content">
    <div class="container container--narrow">
      <div class="gh-content" id="post-content">
        {{content}}
      </div>
    </div>
  </div>

  <!-- ── Post Footer ── -->
  <footer class="post-full-footer">
    <div class="container container--narrow">

      {{#if tags}}
      <div class="post-full-tags" aria-label="Tags">
        <span class="post-full-tags__label">Topics:</span>
        {{#foreach tags}}
          <a href="{{url}}" class="post-full-tags__tag">{{name}}</a>
        {{/foreach}}
      </div>
      {{/if}}

      <div class="post-full-divider" aria-hidden="true"></div>

      <!-- Author bio -->
      {{#foreach authors}}
      <div class="author-card">
        {{#if profile_image}}
        <a href="{{url}}" class="author-card__image-link" aria-hidden="true" tabindex="-1">
          <img class="author-card__image"
            src="{{img_url profile_image size="s"}}"
            alt="{{name}}" loading="lazy" />
        </a>
        {{else}}
        <div class="author-card__initials">{{name.[0]}}</div>
        {{/if}}
        <div class="author-card__content">
          <div class="author-card__meta">
            <a href="{{url}}" class="author-card__name">{{name}}</a>
            {{#if location}}<span class="author-card__location">{{location}}</span>{{/if}}
          </div>
          {{#if bio}}
          <p class="author-card__bio">{{bio}}</p>
          {{/if}}
          <a href="{{url}}" class="author-card__link">
            More by {{name}}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
      {{/foreach}}

      <!-- Subscribe CTA -->
      {{#if @site.members_enabled}}
      {{#unless @member}}
      <div class="post-subscribe-cta">
        <div class="post-subscribe-cta__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </div>
        <h3 class="post-subscribe-cta__heading">Enjoyed this article?</h3>
        <p class="post-subscribe-cta__text">
          Subscribe to The Deep Dive and get endpoint management insights, UEM platform analysis,
          and zero trust strategy delivered to your inbox — free.
        </p>
        <a href="/signup" class="btn btn--primary">Subscribe Free</a>
      </div>
      {{/unless}}
      {{/if}}

    </div>
  </footer>

</article>

<!-- ── Related Posts ── -->
{{#get "posts" filter="tags:[{{primary_tag.slug}}]+id:-{{id}}" limit="3"}}
  {{#if posts}}
  <section class="related-posts" aria-labelledby="related-posts-heading">
    <div class="container">
      <h2 class="related-posts__heading" id="related-posts-heading">Related Articles</h2>
      <div class="post-grid post-grid--3">
        {{#foreach posts}}
          {{> post-card}}
        {{/foreach}}
      </div>
    </div>
  </section>
  {{/if}}
{{/get}}

{{/post}}
