<footer class="site-footer">
  <div class="container">
    <div class="site-footer__inner">

      <div class="site-footer__brand">
        <a href="{{@site.url}}" aria-label="{{@site.title}} — home">
          {{#if @site.logo}}
            <img src="{{@site.logo}}" alt="{{@site.title}}" height="36" class="site-footer__logo" />
          {{else}}
            <span class="site-footer__logo-text">{{@site.title}}</span>
          {{/if}}
        </a>
        <p class="site-footer__description">{{@site.description}}</p>
        <div class="site-footer__social">
          <a href="https://www.linkedin.com/company/uem-architect-consulting" target="_blank" rel="noopener noreferrer" aria-label="UEM Architect on LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="site-footer__links">
        <div>
          <h4 class="site-footer__heading">Navigation</h4>
          <ul>
            {{#foreach navigation}}
              <li><a href="{{url}}">{{label}}</a></li>
            {{/foreach}}
          </ul>
        </div>
        <div>
          <h4 class="site-footer__heading">UEM Architect</h4>
          <ul>
            <li><a href="https://www.uemarchitect.org/services.html" target="_blank" rel="noopener">Services</a></li>
            <li><a href="https://www.uemarchitect.org/who-we-serve.html" target="_blank" rel="noopener">Who We Serve</a></li>
            <li><a href="https://www.uemarchitect.org/our-process.html" target="_blank" rel="noopener">Our Process</a></li>
            <li><a href="https://www.uemarchitect.org/contact.html" target="_blank" rel="noopener">Contact</a></li>
          </ul>
        </div>
      </div>

      {{#if @site.members_enabled}}
      <div class="site-footer__subscribe">
        <h4 class="site-footer__heading">Stay in the Loop</h4>
        <p>Get endpoint management insights delivered to your inbox.</p>
        <form class="footer-subscribe" data-members-form>
          <input type="email" name="email" placeholder="your@email.com"
            data-members-email required autocomplete="email" aria-label="Email address" />
          <button type="submit" class="btn btn--primary">Subscribe</button>
        </form>
      </div>
      {{/if}}

    </div>

    <div class="site-footer__bottom">
      <p>&copy; {{date format="YYYY"}} UEM Architect. All rights reserved.</p>
      <nav aria-label="Legal links">
        <a href="https://www.uemarchitect.org/privacy.html" target="_blank" rel="noopener">Privacy Policy</a>
      </nav>
    </div>
  </div>
</footer>
