{{!< default}}

<section class="error-page">
  <div class="container">
    <div class="error-page__content">
      <div class="error-page__code" aria-hidden="true">{{statusCode}}</div>
      <h1 class="error-page__title">
        {{#if (eq statusCode 404)}}
          Page Not Found
        {{else}}
          Something went wrong
        {{/if}}
      </h1>
      <p class="error-page__description">
        {{#if (eq statusCode 404)}}
          The article or page you're looking for doesn't exist or may have been moved.
        {{else}}
          {{message}}
        {{/if}}
      </p>
      <div class="error-page__actions">
        <a href="{{@site.url}}" class="btn btn--primary">Go to Homepage</a>
        <a href="javascript:history.back()" class="btn btn--ghost">Go Back</a>
      </div>
    </div>
  </div>
</section>
