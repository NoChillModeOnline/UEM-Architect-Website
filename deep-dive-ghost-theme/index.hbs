{{!< default}}

{{#if @custom.show_featured_post}}
  {{#get "posts" filter="featured:true" limit="1"}}
    {{#foreach posts}}
    <section class="featured-hero" aria-label="Featured article">
      <div class="container">
        <div class="featured-hero__inner">

          <div class="featured-hero__content">
            <div class="featured-hero__eyebrow">
              {{#primary_tag}}
                <a href="{{url}}" class="featured-hero__tag">{{name}}</a>
              {{/primary_tag}}
              <span class="featured-hero__label">Featured</span>
            </div>
            <h1 class="featured-hero__title">
              <a href="{{url}}">{{title}}</a>
            </h1>
            {{#if custom_excerpt}}
              <p class="featured-hero__excerpt">{{custom_excerpt}}</p>
            {{else}}
              <p class="featured-hero__excerpt">{{excerpt words="30"}}</p>
            {{/if}}
            <div class="featured-hero__meta">
              {{#foreach authors}}
                {{#if profile_image}}
                  <img class="featured-hero__author-avatar"
                    src="{{img_url profile_image size="xs"}}"
                    alt="{{name}}" loading="lazy" />
                {{else}}
                  <span class="featured-hero__author-initials">{{name.[0]}}</span>
                {{/if}}
              {{/foreach}}
              <div>
                <span class="featured-hero__author-name">
                  {{#foreach authors}}{{name}}{{#unless @last}}, {{/unless}}{{/foreach}}
                </span>
                <div class="featured-hero__details">
                  <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
                  <span aria-hidden="true">·</span>
                  <span>{{reading_time}}</span>
                </div>
              </div>
            </div>
            <a href="{{url}}" class="btn btn--primary featured-hero__cta">
              Read Article
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          {{#if feature_image}}
          <a href="{{url}}" class="featured-hero__image-link" tabindex="-1" aria-hidden="true">
            <img
              class="featured-hero__image"
              src="{{img_url feature_image size="l"}}"
              srcset="{{img_url feature_image size="m"}} 600w,
                      {{img_url feature_image size="l"}} 1000w,
                      {{img_url feature_image size="xl"}} 2000w"
              sizes="(max-width: 960px) 100vw, 50vw"
              alt="{{title}}"
              loading="eager"
            />
          </a>
          {{/if}}

        </div>
      </div>
    </section>
    {{/foreach}}
  {{/get}}
{{/if}}

<div class="home-content">
  <div class="container">

    {{#if @site.members_enabled}}
    {{#unless @member}}
    <div class="subscribe-banner reveal">
      <div class="subscribe-banner__text">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
          <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
        <span>Get endpoint management insights delivered to your inbox — free.</span>
      </div>
      <a href="/signup" class="btn btn--primary btn--sm">Subscribe Free</a>
    </div>
    {{/unless}}
    {{/if}}

    <div class="home-posts">
      <div class="home-posts__header">
        <h2 class="home-posts__heading">Latest Articles</h2>
        {{#get "tags" limit="8"}}
          {{#if tags}}
          <div class="tag-filter" role="list" aria-label="Filter by topic">
            <a href="{{@site.url}}" class="tag-filter__item {{#unless @site.tag}}tag-filter__item--active{{/unless}}" role="listitem">All</a>
            {{#foreach tags}}
            <a href="{{url}}" class="tag-filter__item" role="listitem">{{name}}</a>
            {{/foreach}}
          </div>
          {{/if}}
        {{/get}}
      </div>

      <div class="post-grid">
        {{#foreach posts}}
          {{> post-card}}
        {{/foreach}}
      </div>

      {{pagination}}

    </div>

  </div>
</div>
